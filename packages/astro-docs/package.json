{
	"name": "astro-docs",
	"version": "0.0.0",
	"type": "module",
	"description": "A customizable documentation and book framework for Astro. Bring your own look.",
	"keywords": [
		"astro",
		"astro-integration",
		"astro-component",
		"withastro",
		"docs",
		"documentation",
		"book",
		"pagefind"
	],
	"author": "Shravan Goswami <contact@shravangoswami.com> (https://shravangoswami.com)",
	"license": "MIT",
	"homepage": "https://github.com/shravanngoswamii/astro-docs#readme",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/shravanngoswamii/astro-docs.git",
		"directory": "packages/astro-docs"
	},
	"bugs": "https://github.com/shravanngoswamii/astro-docs/issues",
	"engines": {
		"node": ">=22.12.0"
	},
	"sideEffects": [
		"**/*.css",
		"**/*.astro"
	],
	"exports": {
		".": "./src/integration/index.ts",
		"./components": "./src/components/index.ts",
		"./components/*": "./src/components/*",
		"./schema": "./src/schema/index.ts",
		"./loaders": "./src/loaders.ts",
		"./types": "./src/types.ts",
		"./styles/*": "./src/styles/*",
		"./package.json": "./package.json"
	},
	"files": [
		"src"
	],
	"scripts": {
		"test": "vitest run",
		"test:watch": "vitest",
		"typecheck": "tsc --noEmit"
	},
	"dependencies": {
		"@astrojs/markdown-remark": "^7.2.0",
		"@astrojs/mdx": "^7.0.0",
		"@astrojs/sitemap": "^3.7.3",
		"astro-expressive-code": "^0.44.0",
		"github-slugger": "^2.0.0",
		"hastscript": "^9.0.1",
		"katex": "^0.17.0",
		"mdast-util-directive": "^3.1.0",
		"rehype-katex": "^7.0.1",
		"remark-directive": "^4.0.0",
		"remark-math": "^6.0.0",
		"unist-util-visit": "^5.1.0"
	},
	"peerDependencies": {
		"astro": "^6.0.0 || ^7.0.0",
		"pagefind": "^1.0.0"
	},
	"peerDependenciesMeta": {
		"pagefind": {
			"optional": true
		}
	},
	"devDependencies": {
		"@pagefind/default-ui": "^1.5.2",
		"@types/hast": "^3.0.4",
		"@types/mdast": "^4.0.4",
		"astro": "^7.0.3",
		"pagefind": "^1.5.2",
		"typescript": "^6.0.3",
		"vitest": "^4.1.9"
	},
	"publishConfig": {
		"access": "public"
	}
}
