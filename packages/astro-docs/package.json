{
  "name": "astro-docs",
  "version": "0.2.0",
  "type": "module",
  "description": "A customizable documentation and book framework for Astro. Bring your own look.",
  "keywords": [
    "astro",
    "astro-integration",
    "astro-component",
    "docs",
    "documentation",
    "book"
  ],
  "author": "Shravan Goswami <contact@shravangoswami.com> (https://shravangoswami.com)",
  "license": "MIT",
  "exports": {
    ".": "./src/integration/index.ts",
    "./components": "./src/components/index.ts",
    "./components/*": "./src/components/*",
    "./schema": "./src/schema/index.ts",
    "./loaders": "./src/loaders.ts",
    "./types": "./src/types.ts",
    "./styles/*": "./src/styles/*",
    "./package.json": "./package.json"
  },
  "files": [
    "src"
  ],
  "scripts": {
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@astrojs/mdx": "^6.0.3",
    "@astrojs/sitemap": "^3.7.3",
    "astro-expressive-code": "^0.41.2",
    "github-slugger": "^2.0.0",
    "hastscript": "^9.0.1",
    "katex": "^0.16.11",
    "mdast-util-directive": "^3.1.0",
    "rehype-katex": "^7.0.1",
    "remark-directive": "^4.0.0",
    "remark-math": "^6.0.0",
    "unist-util-visit": "^5.0.0"
  },
  "peerDependencies": {
    "astro": "^5.0.0 || ^6.0.0",
    "pagefind": "^1.0.0"
  },
  "peerDependenciesMeta": {
    "pagefind": {
      "optional": true
    }
  },
  "devDependencies": {
    "@pagefind/default-ui": "^1.5.2",
    "astro": "^6.4.4",
    "pagefind": "^1.5.2",
    "typescript": "^5.7.0",
    "vitest": "^2.1.0"
  }
}
