---
import config from "virtual:astro-docs/config";
import { useTranslations } from "../utils/i18n";

const t = useTranslations(config.defaultLocale);
---

<button
  class="docs-theme-toggle"
  data-theme-toggle
  type="button"
  aria-pressed="false"
  aria-label={t("themeSelect.label")}
  title={t("themeSelect.label")}>◐</button>

<script>
  const KEY = "astro-docs-theme";
  const btn = document.querySelector<HTMLButtonElement>("[data-theme-toggle]");
  const sync = () => {
    btn?.setAttribute(
      "aria-pressed",
      String(document.documentElement.dataset.theme === "dark"),
    );
  };
  sync();
  btn?.addEventListener("click", () => {
    const root = document.documentElement;
    const next = root.dataset.theme === "dark" ? "light" : "dark";
    root.dataset.theme = next;
    sync();
    try {
      localStorage.setItem(KEY, next);
    } catch {
      // localStorage may be unavailable (private mode); toggle still works for the session.
    }
  });
</script>
