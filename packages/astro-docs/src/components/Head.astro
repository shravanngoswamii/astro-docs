---
import config from "virtual:astro-docs/config";
import { joinBase } from "../utils/base";

const route = Astro.locals.astroDocs as import("../types").RouteData;

const siteTitle =
	typeof config.title === "string"
		? config.title
		: (config.title[config.defaultLocale ?? "en"] ??
			Object.values(config.title)[0]);

const pageTitle =
	route.title === siteTitle ? siteTitle : `${route.title} — ${siteTitle}`;

const description = route.description ?? config.description;

const favicon = joinBase(import.meta.env.BASE_URL, config.favicon);
const faviconType = config.favicon.endsWith(".svg")
	? "image/svg+xml"
	: undefined;

const canonical = Astro.site ? new URL(route.url, Astro.site) : undefined;

const escapeAttr = (value: string) =>
	value.replace(/&/g, "&amp;").replace(/"/g, "&quot;");

const escapeText = (value: string) =>
	value.replace(/&/g, "&amp;").replace(/</g, "&lt;").replace(/>/g, "&gt;");

// Elements whose content is raw text per the HTML spec — must NOT be entity-escaped.
const RAW_TEXT = new Set(["script", "style"]);
const VALID_TAG = /^[a-zA-Z][a-zA-Z0-9-]*$/;

const headExtra = (config.head ?? [])
	.filter((entry) => VALID_TAG.test(entry.tag))
	.map((entry) => {
		const attrs = Object.entries(entry.attrs ?? {})
			.map(([key, value]) => {
				if (value === undefined || value === false) return "";
				if (value === true) return ` ${key}`;
				return ` ${key}="${escapeAttr(String(value))}"`;
			})
			.join("");
		const body = entry.content
			? RAW_TEXT.has(entry.tag.toLowerCase())
				? entry.content
				: escapeText(entry.content)
			: "";
		return `<${entry.tag}${attrs}>${body}</${entry.tag}>`;
	})
	.join("\n");
---

<meta charset="utf-8" />
<meta name="viewport" content="width=device-width, initial-scale=1" />
<title>{pageTitle}</title>
{description && <meta name="description" content={description} />}
<link rel="icon" href={favicon} type={faviconType} />
<meta name="generator" content={Astro.generator} />

{canonical && <link rel="canonical" href={canonical.href} />}

<meta property="og:title" content={pageTitle} />
{description && <meta property="og:description" content={description} />}
<meta property="og:type" content="website" />
{canonical && <meta property="og:url" content={canonical.href} />}

{
  config.math && (
    <link
      rel="stylesheet"
      href="https://cdn.jsdelivr.net/npm/katex@0.16.11/dist/katex.min.css"
    />
  )
}

{headExtra && <Fragment set:html={headExtra} />}
