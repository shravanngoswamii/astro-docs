---
import type { SidebarItem } from "../utils/sidebar";

interface Props {
  items: SidebarItem[];
  currentPath?: string;
}

const { items, currentPath } = Astro.props;
---

<nav class="docs-sidebar-nav" aria-label="Documentation">
  <ul class="docs-sidebar-list" role="list">
    {items.map((item) =>
      item.type === "group" ? (
        <li class="docs-sidebar-group">
          <span class="docs-sidebar-group-label">{item.label}</span>
          <ul class="docs-sidebar-list" role="list">
            {item.items.map((child) =>
              child.type === "link" ? (
                <li>
                  <a
                    href={child.href}
                    class:list={["docs-sidebar-link", { "docs-sidebar-link--current": child.href === currentPath }]}
                    aria-current={child.href === currentPath ? "page" : undefined}
                  >
                    {child.label}
                    {child.badge && <span class="docs-sidebar-badge">{child.badge}</span>}
                  </a>
                </li>
              ) : null
            )}
          </ul>
        </li>
      ) : (
        <li>
          <a
            href={item.href}
            class:list={["docs-sidebar-link", { "docs-sidebar-link--current": item.href === currentPath }]}
            aria-current={item.href === currentPath ? "page" : undefined}
          >
            {item.label}
            {item.badge && <span class="docs-sidebar-badge">{item.badge}</span>}
          </a>
        </li>
      )
    )}
  </ul>
</nav>
