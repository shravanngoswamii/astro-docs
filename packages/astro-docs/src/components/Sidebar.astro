---
import type { ResolvedSidebarItem } from "../types";
import config from "virtual:astro-docs/config";
import { useTranslations } from "../utils/i18n";
import Sidebar from "./Sidebar.astro";

interface Props {
	items?: ResolvedSidebarItem[];
}

const t = useTranslations(config.defaultLocale);

const route = Astro.locals.astroDocs;
const { items } = Astro.props;

// When `items` is passed we are a recursive call rendering nested <li>s only;
// otherwise we are the top-level nav rendering route.sidebar with its wrapper.
const isRoot = items === undefined;
const sidebarItems = items ?? route.sidebar;
---

{
  isRoot ? (
    <nav class="docs-sidebar-nav" aria-label={t("sidebar.label")}>
      <ul class="docs-sidebar-list" role="list">
        <Sidebar items={sidebarItems} />
      </ul>
    </nav>
  ) : (
    sidebarItems.map((item) =>
      item.type === "link" ? (
        <li>
          <a
            class:list={[
              "docs-sidebar-link",
              { "docs-sidebar-link--current": item.isCurrent },
            ]}
            href={item.href}
            aria-current={item.isCurrent ? "page" : undefined}
          >
            {item.label}
            {item.badge && <span class="docs-badge">{item.badge.text}</span>}
          </a>
        </li>
      ) : (
        <li>
          <details class="docs-sidebar-group" open={!item.collapsed}>
            <summary class="docs-sidebar-group-label">
              {item.href ? (
                <a
                  class:list={["docs-sidebar-group-link", { "docs-sidebar-link--current": item.hasCurrent && item.href === route.url }]}
                  href={item.href}
                >
                  {item.label}
                </a>
              ) : (
                item.label
              )}
              {item.badge && <span class="docs-badge">{item.badge.text}</span>}
            </summary>
            <ul class="docs-sidebar-list" role="list">
              <Sidebar items={item.items} />
            </ul>
          </details>
        </li>
      ),
    )
  )
}
