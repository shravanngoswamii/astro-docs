---
import config from "virtual:astro-docs/config";
import { useTranslations } from "../utils/i18n";

const route = Astro.locals.astroDocs;
const t = useTranslations(config.defaultLocale);

const crumbs = route.breadcrumbs;
const last = crumbs.length - 1;
---

{
  crumbs.length > 1 && (
    <nav class="docs-breadcrumbs" aria-label={t("breadcrumbs.label")}>
      <ol class="docs-breadcrumbs-list">
        {crumbs.map((c, i) => (
          <li class="docs-breadcrumbs-item">
            {c.href ? (
              <a href={c.href}>{c.label}</a>
            ) : (
              <span aria-current="page">{c.label}</span>
            )}
            {i < last && (
              <span class="docs-breadcrumbs-sep" aria-hidden="true">
                /
              </span>
            )}
          </li>
        ))}
      </ol>
    </nav>
  )
}
