---
import type { SidebarLink } from "../utils/sidebar";

interface Props {
  prev?: SidebarLink;
  next?: SidebarLink;
}

const { prev, next } = Astro.props;
---

{(prev || next) && (
  <nav class="docs-prevnext" aria-label="Page navigation">
    <div class="docs-prevnext-inner">
      {prev ? (
        <a href={prev.href} class="docs-prevnext-link docs-prevnext-link--prev">
          <span class="docs-prevnext-dir">Previous</span>
          <span class="docs-prevnext-label">{prev.label}</span>
        </a>
      ) : <div />}
      {next ? (
        <a href={next.href} class="docs-prevnext-link docs-prevnext-link--next">
          <span class="docs-prevnext-dir">Next</span>
          <span class="docs-prevnext-label">{next.label}</span>
        </a>
      ) : <div />}
    </div>
  </nav>
)}
