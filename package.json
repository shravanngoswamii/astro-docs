{
	"name": "astro-docs-workspace",
	"private": true,
	"type": "module",
	"packageManager": "pnpm@10.33.4",
	"engines": {
		"node": ">=22.12.0"
	},
	"scripts": {
		"prepare": "git config core.hooksPath .githooks || exit 0",
		"dev": "pnpm --filter playground dev",
		"build": "pnpm --filter playground build",
		"preview": "pnpm --filter playground preview",
		"test": "pnpm --filter astro-docs test",
		"typecheck": "pnpm --filter astro-docs typecheck",
		"check": "biome check .",
		"format": "biome format --write .",
		"lint": "biome lint .",
		"fix": "biome check --write .",
		"verify": "pnpm check && pnpm typecheck && pnpm test && pnpm build",
		"changeset": "changeset",
		"version-packages": "changeset version",
		"release": "changeset publish"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.5.0",
		"@changesets/cli": "^2.31.0",
		"@types/node": "^25.6.2",
		"typescript": "^6.0.3"
	}
}
